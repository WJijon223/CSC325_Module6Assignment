<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.csc325_firebase_webview_auth.view.RegistrationFormController"
            prefHeight="400.0" prefWidth="600.0">
    <VBox spacing="10.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="20.0">
        <Label text="Registration Form" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Label text="First Name:"/>
        <TextField fx:id="firstNameField" promptText="Enter your first name"/>
        <Label text="Last Name:"/>
        <TextField fx:id="lastNameField" promptText="Enter your last name"/>
        <Label text="Email:"/>
        <TextField fx:id="emailField" promptText="Enter your email"/>
        <Label text="Password:"/>
        <PasswordField fx:id="passwordField" promptText="Enter your password"/>
        <Label text="Confirm Password:"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password"/>
        <Button fx:id="registerButton" text="Register" onAction="#handleRegister"/>
        <Hyperlink fx:id="loginLink" text="Already have an account? Login here" onAction="#handleLoginLink"/>
    </VBox>
</AnchorPane>
