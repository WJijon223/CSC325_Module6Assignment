<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.csc325_firebase_webview_auth.view.LoginController"
            prefHeight="400.0" prefWidth="600.0">
    <VBox spacing="10.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="20.0">
        <Label text="Login" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Label text="Email:"/>
        <TextField fx:id="emailField" promptText="Enter your email"/>
        <Label text="Password:"/>
        <PasswordField fx:id="passwordField" promptText="Enter your password"/>
        <Button fx:id="loginButton" text="Login" onAction="#handleLogin"/>
        <Hyperlink fx:id="registerLink" text="Don't have an account? Register here" onAction="#handleRegisterLink"/>
    </VBox>
</AnchorPane>
